---
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';

const current = [
  {
    term: '2025/26',
    code: 'UG · 5 ECTS',
    title: 'New Media and Web Technologies',
    inst: 'Croatian Catholic University',
    description: 'Web infrastructure, content management systems, strategic communication planning, AI implications, and digital analytics. Students learn to critically evaluate and implement web communication strategies.',
    href: 'https://lusiki.github.io/Novi-mediji-i-web-tehnologije/',
  },
  {
    term: '2024/25',
    code: 'UG · 6 ECTS',
    title: 'Fundamentals of Statistics',
    inst: 'Croatian Catholic University',
    description: 'Statistical foundations for communication students. Descriptive statistics, probability theory, hypothesis testing, and inferential statistics in R (tidyverse, ggplot2), with examples from media and communications.',
    href: 'https://lusiki.github.io/Osnove-statistike/',
  },
];

const previous = [
  {
    term: '2021/22',
    code: 'Graduate',
    title: 'Data Processing',
    inst: 'Faculty of Croatian Studies, Zagreb',
    description: 'Data types and sources, R programming, data visualisation, web scraping, machine learning, text analysis, and reproducible reporting. For graduate sociology and social science students.',
    href: 'https://lusiki.github.io/WebObradaPodataka/',
  },
  {
    term: '2021/22',
    code: 'Graduate',
    title: 'Learning Social Media Analytics',
    inst: 'Faculty of Croatian Studies, Zagreb',
    description: 'Computational approaches to social media data. Platform-specific analysis (Twitter, Facebook, Instagram, LinkedIn), data infrastructure, statistical methods, and open-source analytics tools.',
    href: 'https://lusiki.github.io/Learning-Social-Media-Analytics/',
  },
  {
    term: '2021/22',
    code: 'Graduate',
    title: 'Machine Text Processing',
    inst: 'Faculty of Croatian Studies, Zagreb',
    description: 'Computational text analysis from data preparation through NLP. Dictionary methods, supervised and unsupervised machine learning, topic modelling, and text clustering in R.',
    href: 'https://github.com/lusiki/Analiza-teksta',
  },
  {
    term: '2020/21',
    code: 'UG',
    title: 'Application of Statistics in Social Research',
    inst: 'Faculty of Croatian Studies, Zagreb',
    description: 'R programming, descriptive statistics, data visualisation, hypothesis testing, categorical analysis, ANOVA, and linear regression for undergraduate social science students.',
    href: 'https://lusiki.github.io/WebStatistika/',
  },
];
---
<Base title="Teaching — Luka Šikić">
  <section class="hero" style="padding: var(--s-9) 0 var(--s-7);">
    <span class="hero__eyebrow eyebrow">04 — Teaching</span>
    <h1 class="hero__title" style="font-size: 44px; max-width: 24ch;">Courses</h1>
    <p class="hero__lede">Statistics, data science, and digital media. All course materials are public — code and exercises on <a href="https://github.com/lusiki" target="_blank" rel="noopener">GitHub</a>.</p>
  </section>

  <section class="section" style="padding-top: 0; border-top: none;">
    <SectionHeader num="Current" title="2024/25 — 2025/26" />
    <ul class="list">
      {current.map(c => (
        <li>
          <div class="teach">
            <div class="teach__term">
              <div>{c.term}</div>
              <div style="margin-top: 2px; font-size: 11px; font-family: var(--font-mono); color: var(--muted);">{c.code}</div>
            </div>
            <div>
              <div class="teach__course">
                <a href={c.href} target="_blank" rel="noopener" style="border-bottom: 0;">{c.title}</a>
              </div>
              <span class="teach__inst">{c.inst}</span>
              <p style="margin: var(--s-2) 0 0; font-size: 14px; color: var(--muted); max-width: 60ch; line-height: 1.55;">{c.description}</p>
            </div>
            <a class="teach__link" href={c.href} target="_blank" rel="noopener">Materials →</a>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <section class="section">
    <SectionHeader num="Previous" title="2020/21 — 2021/22" />
    <ul class="list">
      {previous.map(c => (
        <li>
          <div class="teach">
            <div class="teach__term">
              <div>{c.term}</div>
              <div style="margin-top: 2px; font-size: 11px; font-family: var(--font-mono); color: var(--muted);">{c.code}</div>
            </div>
            <div>
              <div class="teach__course">
                <a href={c.href} target="_blank" rel="noopener" style="border-bottom: 0;">{c.title}</a>
              </div>
              <span class="teach__inst">{c.inst}</span>
              <p style="margin: var(--s-2) 0 0; font-size: 14px; color: var(--muted); max-width: 60ch; line-height: 1.55;">{c.description}</p>
            </div>
            <a class="teach__link" href={c.href} target="_blank" rel="noopener">Materials →</a>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <section class="section">
    <SectionHeader num="—" title="Workshops" />
    <div class="prose" style="max-width: 60ch;">
      <p>I run analytics workshops for institutions and organisations, including the <strong>Economic Institute Zagreb</strong>. Topics include applied econometrics, machine learning for non-specialists, and data-driven decision-making. Get in touch at <a href="mailto:luka.sikic@unicath.hr">luka.sikic@unicath.hr</a> to discuss.</p>
    </div>
  </section>
</Base>
