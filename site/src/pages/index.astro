---
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PublicationRow from '../components/PublicationRow.astro';
import { getCollection } from 'astro:content';
import { strings, type Lang } from '../i18n/strings';

const lang: Lang = 'en';
const s = strings[lang];
const prefix = lang === 'hr' ? '/hr' : '';

const pubs = (await getCollection('publications')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const selectedPubs = pubs.slice(0, 4);
---
<Base title={s.home.title} lang={lang}>
  <section class="hero hero--portrait">
    <div class="hero__main">
      <span class="hero__eyebrow eyebrow">{s.home.eyebrow}</span>
      <h1 class="hero__title">{s.home.heroTitle}</h1>
      <div class="prose" style="max-width: 60ch;">
        <p set:html={s.home.bio1} />
        <p set:html={s.home.bio2} />
      </div>
      <div class="hero__meta">
        <span><strong>{s.home.metaRole}</strong> · {s.home.metaRoleSub}</span>
        <span><strong>{s.home.metaWorkshops}</strong> · {s.home.metaWorkshopsSub}</span>
        <span><strong>{s.home.metaCollab}</strong> · {s.home.metaCollabSub}</span>
      </div>
    </div>
    <aside class="hero__portrait">
      <img src="/avatar.png" alt="Luka Šikić" width="160" height="160" />
      <div class="hero__portrait-meta">
        <span class="eyebrow">Luka Šikić</span>
        <span class="mono" style="font-size: 12px; color: var(--muted);">Zagreb · HR</span>
      </div>
    </aside>
  </section>

  <section class="section">
    <SectionHeader num={s.home.selectedWork} title={s.home.selectedWorkTitle} />
    <ul class="list">
      {s.home.selectedWorkItems.map(w => (
        <li>
          <article class="pub">
            <div class="pub__year">{w.year}</div>
            <div>
              {w.href
                ? <a class="pub__title" href={w.href} target="_blank" rel="noopener">{w.title}</a>
                : <div class="pub__title">{w.title}</div>}
              <span class="pub__venue">{w.body}</span>
            </div>
            <div class="pub__links">
              {w.href && <a href={w.href} target="_blank" rel="noopener">LINK</a>}
            </div>
          </article>
        </li>
      ))}
    </ul>
  </section>

  <section class="section">
    <SectionHeader num={s.home.research} title={s.home.researchTitle} />
    <ul class="list">
      {selectedPubs.map(p => <li><PublicationRow entry={p} lang={lang} /></li>)}
    </ul>
    <div style="margin-top: var(--s-5);">
      <a href={`${prefix}/publications/`} class="btn">{s.home.allPubs}</a>
    </div>
  </section>

  <section class="section">
    <SectionHeader num={s.home.background} title={s.home.backgroundTitle} />
    <div class="prose" style="max-width: 65ch;">
      <p>{s.home.backgroundBody}</p>
    </div>
  </section>

  <section class="section">
    <SectionHeader num={s.home.contact} title={s.home.contactTitle} />
    <div class="prose" style="max-width: 60ch;">
      <p set:html={s.home.contactBody} />
    </div>
    <div style="display: flex; gap: var(--s-2); flex-wrap: wrap; margin-top: var(--s-5);">
      <a class="btn btn--primary" href="mailto:luka.sikic@unicath.hr">{s.home.btnEmail}</a>
      <a class="btn" href="https://github.com/lusiki" target="_blank" rel="noopener">{s.home.btnGithub}</a>
      <a class="btn" href="https://scholar.google.com/citations?user=qOGfRvkAAAAJ&hl=en" target="_blank" rel="noopener">{s.home.btnScholar}</a>
      <a class="btn" href="https://www.linkedin.com/in/luka-sikic-662ba869/" target="_blank" rel="noopener">{s.home.btnLinkedin}</a>
    </div>
  </section>
</Base>
