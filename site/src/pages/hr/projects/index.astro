---
import Base from '../../../layouts/Base.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import ProjectRow from '../../../components/ProjectRow.astro';
import { getCollection } from 'astro:content';
import { strings, type Lang } from '../../../i18n/strings';

const lang: Lang = 'hr';
const s = strings[lang];

const projects = (await getCollection('projects')).sort(
  (a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0),
);
---
<Base title={s.projects.title} lang={lang}>
  <section class="hero" style="padding: var(--s-9) 0 var(--s-7);">
    <span class="hero__eyebrow eyebrow">{s.projects.eyebrow}</span>
    <h1 class="hero__title" style="font-size: 44px; max-width: 24ch;">{s.projects.heroTitle}</h1>
    <p class="hero__lede">{s.projects.hero}</p>
  </section>

  <section class="section" style="padding-top: 0; border-top: none;">
    <SectionHeader num={s.projects.sectionLabel(projects.length)} title={s.projects.sectionTitle} />
    <ul class="list">
      {projects.map(p => <li><ProjectRow entry={p} lang={lang} /></li>)}
    </ul>
  </section>
</Base>
