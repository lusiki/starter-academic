---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { strings, type Lang } from '../../../i18n/strings';

const lang: Lang = 'hr';
const s = strings[lang];
const prefix = '/hr';

export async function getStaticPaths() {
  const pubs = await getCollection('publications');
  return pubs.map(entry => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;
const year = d.date.getFullYear();
const abstract = d.abstract_hr || d.abstract;
---
<Base title={`${d.title} — Luka Šikić`} description={abstract?.slice(0, 200)} lang={lang}>
  <article class="prose" style="padding: var(--s-9) 0;">
    <div style="margin-bottom: var(--s-5);">
      <a href={`${prefix}/publications/`} class="eyebrow" style="border-bottom: 0;">{s.pubs.back}</a>
    </div>

    <div class="eyebrow" style="margin-bottom: var(--s-4);">
      {year} · {d.publication_type || 'Publikacija'}
    </div>

    <h1 style="font-size: 36px; line-height: 1.15; margin-bottom: var(--s-5); max-width: 28ch;">{d.title}</h1>

    {d.authors.length > 0 && (
      <p class="mono" style="color: var(--muted); font-size: 14px; margin-bottom: var(--s-3);">
        {d.authors.join(' · ')}
      </p>
    )}

    {d.publication && (
      <p style="color: var(--muted); margin-bottom: var(--s-6);" set:html={d.publication.replace(/_([^_]+)_/g, '<em>$1</em>')} />
    )}

    <div style="display: flex; gap: var(--s-2); flex-wrap: wrap; margin-bottom: var(--s-7);">
      {d.url_pdf && <a class="btn" href={d.url_pdf} target="_blank" rel="noopener">PDF</a>}
      {d.url_code && <a class="btn" href={d.url_code} target="_blank" rel="noopener">Kod</a>}
      {d.url_preprint && <a class="btn" href={d.url_preprint} target="_blank" rel="noopener">Preprint</a>}
      {d.url_slides && <a class="btn" href={d.url_slides} target="_blank" rel="noopener">Prezentacija</a>}
      {d.url_project && <a class="btn" href={d.url_project} target="_blank" rel="noopener">Analiza</a>}
      {d.doi && <a class="btn" href={`https://doi.org/${d.doi}`} target="_blank" rel="noopener">DOI</a>}
    </div>

    {abstract && (
      <>
        <div class="eyebrow" style="margin-bottom: var(--s-3);">{s.pubs.abstract}</div>
        <p>{abstract}</p>
      </>
    )}

    {d.tags && d.tags.length > 0 && (
      <div style="margin: var(--s-7) 0; display: flex; gap: var(--s-2); flex-wrap: wrap;">
        {d.tags.map(t => <span class="tag">{t}</span>)}
      </div>
    )}

    <Content />

    {d.bibtex && (
      <>
        <div class="eyebrow" style="margin: var(--s-7) 0 var(--s-3);">{s.pubs.bibtex}</div>
        <pre>{d.bibtex}</pre>
      </>
    )}
  </article>
</Base>
