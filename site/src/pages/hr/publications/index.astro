---
import Base from '../../../layouts/Base.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import PublicationRow from '../../../components/PublicationRow.astro';
import { getCollection } from 'astro:content';
import { strings, type Lang } from '../../../i18n/strings';

const lang: Lang = 'hr';
const s = strings[lang];

const pubs = (await getCollection('publications')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---
<Base title={s.pubs.title} lang={lang}>
  <section class="hero" style="padding: var(--s-9) 0 var(--s-7);">
    <span class="hero__eyebrow eyebrow">{s.pubs.eyebrow}</span>
    <h1 class="hero__title" style="font-size: 44px; max-width: 24ch;">{s.pubs.heroTitle}</h1>
    <p class="hero__lede">{s.pubs.hero}</p>
  </section>

  <section class="section" style="padding-top: 0; border-top: none;">
    <SectionHeader num={s.pubs.sectionLabel(pubs.length)} title={s.pubs.sectionTitle} />
    <ul class="list">
      {pubs.map(p => <li><PublicationRow entry={p} lang={lang} /></li>)}
    </ul>
  </section>
</Base>
