    <div class="footer__links">
      <a href="mailto:luka.sikic@unicath.hr">{s.home.btnEmail}</a>
      <a href="https://scholar.google.com/citations?user=qOGfRvkAAAAJ&hl=en">Scholar</a>
      <a href="https://github.com/lusiki">GitHub</a>
      <a href="https://www.linkedin.com/in/luka-sikic-662ba869/">LinkedIn</a>
    </div>
  </div>
</footer>
