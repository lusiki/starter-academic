---
import type { CollectionEntry } from 'astro:content';
interface Props { entry: CollectionEntry<'publications'>; }
const { entry } = Astro.props;
const d = entry.data;
const year = d.date.getFullYear();
const href = `/publications/${entry.slug}/`;
---
<article class="pub">
  <div class="pub__year">{year}</div>
  <div>
    <a href={href} class="pub__title">{d.title}</a>
    {d.publication && <span class="pub__venue" set:html={d.publication.replace(/_([^_]+)_/g, '<em>$1</em>')} />}
  </div>
  <div class="pub__links">
    {d.url_pdf && <a href={d.url_pdf} target="_blank" rel="noopener">PDF</a>}
    {d.bibtex && <a href={href}>BIB</a>}
    {d.doi && <a href={`https://doi.org/${d.doi}`} target="_blank" rel="noopener">DOI</a>}
  </div>
</article>
