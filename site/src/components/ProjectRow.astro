---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '../i18n/strings';
interface Props { entry: CollectionEntry<'projects'>; lang?: Lang; }
const { entry, lang = 'en' } = Astro.props;
const d = entry.data;
const prefix = lang === 'hr' ? '/hr' : '';
const summary = (lang === 'hr' && d.summary_hr) ? d.summary_hr : d.summary;
const href = d.external_link || `${prefix}/projects/${entry.slug}/`;
const ext = !!d.external_link;
---
<article class="pub">
  <div class="pub__year">{d.date ? d.date.getFullYear() : ''}</div>
  <div>
    <a href={href} class="pub__title" target={ext ? '_blank' : undefined} rel={ext ? 'noopener' : undefined}>{d.title}</a>
    {summary && <span class="pub__venue">{summary}</span>}
  </div>
  <div class="pub__links">
    {d.url_code && <a href={d.url_code} target="_blank" rel="noopener">CODE</a>}
    {d.url_pdf && <a href={d.url_pdf} target="_blank" rel="noopener">PDF</a>}
  </div>
</article>
