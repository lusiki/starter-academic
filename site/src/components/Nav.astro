---
import { strings, altLang, altPath, type Lang } from '../i18n/strings';
interface Props { lang?: Lang; }
const { lang = 'en' } = Astro.props;
const s = strings[lang];
const { pathname } = Astro.url;
const prefix = lang === 'hr' ? '/hr' : '';
const links = [
  { href: `${prefix}/`, label: s.nav.about },
  { href: `${prefix}/publications/`, label: s.nav.research },
  { href: `${prefix}/projects/`, label: s.nav.projects },
  { href: `${prefix}/teaching/`, label: s.nav.teaching },
];
const isActive = (p: string) => {
  if (p === `${prefix}/`) return pathname === p;
  return pathname === p || pathname.startsWith(p);
};
const altHref = altPath(pathname, lang);
const other = altLang(lang);
---
<nav class="nav" aria-label="Primary">
  <div class="nav__inner">
    <a class="nav__brand" href={`${prefix}/`}><span class="dot"></span> {s.brand}</a>
    <div class="nav__links">
      {links.map(l => (
        <a class="nav__link" href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>{l.label}</a>
      ))}
      <a class="nav__link" href={altHref} aria-label={other === 'hr' ? 'Hrvatski' : 'English'}>{other.toUpperCase()}</a>
      <button class="nav__theme-toggle" id="themeToggle" aria-label="Toggle theme" title="Toggle theme">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</nav>
